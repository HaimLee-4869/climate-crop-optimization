# ─────────────────────────────────────────────────────────────
# 데이터 — 용량(약 350MB) 및 재배포 라이선스 문제로 제외
# 원본은 별도 다운로드 필요 (README 참조)
# ─────────────────────────────────────────────────────────────
data/

# 학습된 모델 파일 (재현 가능하므로 커밋하지 않음)
*.joblib
*.pkl
*.pickle
*.cbm
*.model

# 중간 산출물 포맷
*.parquet
*.feather
*.h5
*.hdf5

# ─────────────────────────────────────────────────────────────
# outputs — 그림과 표는 포함, 나머지는 제외
# ─────────────────────────────────────────────────────────────
outputs/*
!outputs/figures/
!outputs/results/
!outputs/corn_project_report.docx

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 가상환경
.venv/
venv/
env/
ENV/
.conda/

# ─────────────────────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ─────────────────────────────────────────────────────────────
# 에디터 / OS
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# 임시 파일
*.tmp
*.bak
*.log
~$*.docx
~$*.xlsx
